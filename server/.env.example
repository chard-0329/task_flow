PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=student_task_manager

# Railway MySQL provides these automatically when a MySQL service is attached.
# The server supports either the DB_* variables above or these MYSQL* variables.
MYSQLHOST=
MYSQLPORT=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=

JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=7d
